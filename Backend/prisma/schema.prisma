// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// model for user perspective 

model UserAuth {
  id                    Int                  @id @default(autoincrement())
  name                  String
  password              String
  isAuthenticated       Boolean              @default(false)
  email                 String               @unique
  createdAt             DateTime             @default(now())
  updateAt              DateTime             @updatedAt
  userDetails           UserDetails?
  otp                   Int?
  posts                 Posts[]
  followers             Follow[]             @relation("Followers")
  following             Follow[]             @relation("Following")
  postComments          PostComments[]
  likeDislikeComments   LikeDislikeComment[]
  NotificationRecipient Notification[]       @relation("NotificationRecipient")
  NotificationActor     Notification[]       @relation("NotificationActor")

  sentMessages     Message[]   @relation("MessageSender")
  receivedMessages Message[]   @relation("MessageReceiver")
  postLikes        PostLikes[]
}

model UserDetails {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  profileImage    String
  backgroundImage String
  Biodescription  String
  location        String
  joiningDate     String?
  handleUrl       String?
  createdAt       DateTime @default(now())
  updateAt        DateTime @updatedAt

  User UserAuth @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// model for post perspective 
model Posts {
  id          Int      @id @default(autoincrement())
  userId      Int
  description String
  Images      String[]
  videos      String[]
  createdAt   DateTime @default(now())
  updateAt    DateTime @updatedAt

  User          UserAuth       @relation(fields: [userId], references: [id], onDelete: Cascade)
  postComments  PostComments[]
  notifications Notification[]
  postLikes     PostLikes[]

  @@index([userId, createdAt])
  @@index([createdAt])
}

model PostLikes {
  id     Int @id @default(autoincrement())
  postId Int
  userId Int

  Posts          Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  PostsLikeUsers UserAuth @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updateAt       DateTime @updatedAt

  @@unique([postId, userId])
  @@index([postId, userId])
}

// model for post comment perspective 
model PostComments {
  id          Int    @id @default(autoincrement())
  postId      Int
  commenterId Int
  message     String

  Post                Posts                @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt           DateTime             @default(now())
  updateAt            DateTime             @updatedAt
  CommentUser         UserAuth             @relation(fields: [commenterId], references: [id], onDelete: Cascade)
  likeDislikeComments LikeDislikeComment[]
  notifications       Notification[]

  @@index([postId, createdAt])
  @@index([createdAt])
}

// model for post dislike and like perspective 
model LikeDislikeComment {
  id                 Int          @id @default(autoincrement())
  commentId          Int
  userId             Int
  LikeAndDislikeUser UserAuth     @relation(fields: [userId], references: [id], onDelete: Cascade)
  PostComment        PostComments @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt          DateTime     @default(now())
  updateAt           DateTime     @updatedAt
}

// model for user follow and unfollow perspective 
model Follow {
  id Int @id @default(autoincrement())

  followerId  Int
  followingId Int

  follower  UserAuth @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following UserAuth @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

// model for notification perspective  type for notifications is 
// Like, comment ,new post , or comment like 

enum NotificationType {
  FOLLOW
  LIKE_POST
  LIKE_COMMENT
  COMMENT
}

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Who receives this notification
  recipient   UserAuth @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId Int

  // Who triggered it (the follower, the liker, the commenter)
  actor   UserAuth @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  actorId Int

  // Optional links to the relevant entity, depending on type
  post   Posts? @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int?

  comment   PostComments? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId Int?

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
}

// model for chats between users 

model Message {
  id      Int     @id @default(autoincrement())
  content String?
  file    String?
  image   String?

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   UserAuth @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId Int

  receiver   UserAuth @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId Int

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
  @@index([createdAt])
}

model Postbookmarks {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
